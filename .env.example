# Root `.env` for docker-compose.prod.yml (not api/.env).

# --- Required ---
POSTGRES_PASSWORD=change-me-strong-db-password
SECRET_KEY=change-me-min-32-chars-use-python-secrets-token-urlsafe-48

FRONTEND_URL=https://cadencemusik.com
NEXT_PUBLIC_API_URL=https://api.cadencemusik.com

# Path-style API URL (e.g. https://site.com/api): optional API_ROOT_PATH / API_FORCE_NO_PREFIX — see README.

# --- Demo (optional) ---
DEMO_LOGIN_ENABLED=true
DEMO_USER_EMAIL=demo@cadence.local
DEMO_USER_PASSWORD=ReplaceWithYourPublicDemoPassword
DEMO_LOGIN_AUTO_CREATE=true
DEMO_SEED_AT_STARTUP=true
NEXT_PUBLIC_DEMO_LOGIN=true
# NEXT_PUBLIC_DEMO_LOGIN=false

# --- Optional ---
# ENVIRONMENT=production
# TRUSTED_HOSTS=api.cadencemusik.com
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=
# RESEND_API_KEY=
# EMAIL_FROM=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# SENTRY_DSN=
