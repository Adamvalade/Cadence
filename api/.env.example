DATABASE_URL=postgresql+asyncpg://cadence:cadence@localhost:5433/cadence
REDIS_URL=redis://localhost:6379
# Local dev: any string. Production (ENVIRONMENT=production): min 32 chars, not a placeholder — generate with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-random-string
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Register this in Spotify (use 127.0.0.1 — "localhost" is rejected as insecure in Safari / new Spotify rules).
# Run ./bin/ssl-localhost.sh then set NEXT_PUBLIC_API_URL=https://127.0.0.1:8000 in web/.env.local
SPOTIFY_REDIRECT_URI=https://127.0.0.1:8000/auth/spotify/callback
# ISO country code for Spotify catalog (search / album metadata)
SPOTIFY_MARKET=US
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Browser origin for CORS + OAuth redirects (scheme + host + port must match exactly)
FRONTEND_URL=http://localhost:3000

# development | production — production disables /docs and enforces SECRET_KEY + FRONTEND_URL rules
ENVIRONMENT=development

# Production only: comma-separated hostnames the API is served as (TrustedHostMiddleware). Leave empty behind a reverse proxy that sets Host oddly.
# TRUSTED_HOSTS=api.example.com

# Optional error reporting (API only; see deploy/README.md for Next.js).
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Docker entrypoint (production): read secrets from files instead of env (see deploy/docker-compose.secrets.yml).
# SECRET_KEY_FILE=/run/secrets/secret_key
# POSTGRES_PASSWORD_FILE=/run/secrets/postgres_password
# Or a single line (no newline): DATABASE_URL_FILE=/run/secrets/database_url
