# =============================================================================
# Docker Compose uses THIS file’s sibling: `.env` in the REPO ROOT (same folder
# as docker-compose.prod.yml). Copy once:
#   cp .env.example .env
# Then edit `.env`. You do NOT need `export`; Compose reads `.env` automatically.
#
# `api/.env` is NOT loaded by docker-compose.prod.yml — only this root `.env`
# (and variables listed under each service’s `environment:` block) matter for deploy.
# =============================================================================

# --- Required for docker-compose.prod.yml ---
POSTGRES_PASSWORD=change-me-strong-db-password
SECRET_KEY=change-me-min-32-chars-use-python-secrets-token-urlsafe-48

# Public site URL (browser). Must match where users open the Next app.
FRONTEND_URL=https://cadencemusik.com

# Public API base URL (what the browser calls). Often https://api.yourdomain.com
NEXT_PUBLIC_API_URL=https://api.cadencemusik.com

# Same host under /api (e.g. https://yoursite.com/api/...): you do NOT need API_ROOT_PATH — the API
# infers a /api mount from NEXT_PUBLIC_API_URL. If your edge strips /api before the container, set:
# API_FORCE_NO_PREFIX=true
# Optional explicit prefix override: API_ROOT_PATH=/api (or /v1, etc.)

# --- Recruiter demo (optional) ---
# “Try demo” on login + seeded fake friends/reviews. Minimum to add: the two lines below
# (compose already defaults the rest). DEMO_USER_PASSWORD is only read by the server—
# visitors never type it; pick any 8+ char value, don’t reuse a real personal password.
DEMO_LOGIN_ENABLED=true
DEMO_USER_EMAIL=demo@cadence.local
DEMO_USER_PASSWORD=ReplaceWithYourPublicDemoPassword
DEMO_LOGIN_AUTO_CREATE=true
DEMO_SEED_AT_STARTUP=true

# Baked into the web image at build time — set true with demo above so the login page shows “Try demo”.
NEXT_PUBLIC_DEMO_LOGIN=true

# Optional: force-hide demo button on web even if API enables it
# NEXT_PUBLIC_DEMO_LOGIN=false

# --- Optional ---
# ENVIRONMENT=production
# TRUSTED_HOSTS=api.cadencemusik.com
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=
# RESEND_API_KEY=
# EMAIL_FROM=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# SENTRY_DSN=
