# =============================================================================
# LOCAL uvicorn / pytest only — Pydantic loads this file when you work in api/.
#
# Docker Compose (docker-compose.prod.yml) does NOT read api/.env. For deploy,
# put POSTGRES_PASSWORD, SECRET_KEY, FRONTEND_URL, NEXT_PUBLIC_API_URL, DEMO_*,
# etc. in the repo ROOT `.env` (see `/.env.example` in the project root).
# =============================================================================

DATABASE_URL=postgresql+asyncpg://cadence:cadence@localhost:5433/cadence
REDIS_URL=redis://localhost:6379
# Local dev: any string. Production (ENVIRONMENT=production): min 32 chars, not a placeholder — generate with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-random-string
# Spotify — https://developer.spotify.com/dashboard
# Search/import use CLIENT_ID + CLIENT_SECRET (client credentials). REDIRECT_URI is optional in the app
# but keep it aligned with anything you register in the Spotify app (harmless if set).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=
SPOTIFY_MARKET=US

# Password reset emails (https://resend.com). If unset, dev logs the reset URL; production logs a warning.
# RESEND_API_KEY=
# EMAIL_FROM=Cadence <onboarding@yourdomain.com>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Browser origin for CORS + OAuth redirects (scheme + host + port must match exactly)
FRONTEND_URL=http://localhost:3000

# development | production — production disables /docs and enforces SECRET_KEY + FRONTEND_URL rules
ENVIRONMENT=development

# Optional: mount all routers under a path (e.g. /api) when the edge forwards /api/* without stripping.
# API_ROOT_PATH=/api

# Demo for recruiters (POST /auth/demo-login + GET /auth/demo-status). Off by default.
# When enabled, the API seeds fake users, albums, reviews, and likes at startup (idempotent),
# and each demo login follows those users + adds a sample review/likes for a full feed.
# DEMO_LOGIN_ENABLED=true
# DEMO_USER_EMAIL=demo@cadence.local
# DEMO_USER_PASSWORD=use-a-shared-demo-password-16chars
# DEMO_LOGIN_AUTO_CREATE=true
# DEMO_SEED_AT_STARTUP=true

# Production only: comma-separated hostnames the API is served as (TrustedHostMiddleware). Leave empty behind a reverse proxy that sets Host oddly.
# TRUSTED_HOSTS=api.example.com

# Optional error reporting (API only; see deploy/README.md for Next.js).
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Docker entrypoint (production): read secrets from files instead of env (see deploy/docker-compose.secrets.yml).
# SECRET_KEY_FILE=/run/secrets/secret_key
# POSTGRES_PASSWORD_FILE=/run/secrets/postgres_password
# Or a single line (no newline): DATABASE_URL_FILE=/run/secrets/database_url
